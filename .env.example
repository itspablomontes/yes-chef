# Yes Chef — Environment Variables

# Required
OPENAI_API_KEY=sk-your-openai-api-key-here
# Default: yeschef.db in Docker, yeschef_local.db locally. Override to use a custom path.
DATABASE_URL=sqlite+aiosqlite:///./data/yeschef.db

# Optional (defaults shown)
OPENAI_MODEL=gpt-4o-mini
BATCH_SIZE=5
PLANNING_POOL_SIZE=6
LOG_LEVEL=INFO
APP_ENV=development
DEBUG=false
